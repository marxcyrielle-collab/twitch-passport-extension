generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Season {
  id        String    @id @default(cuid())
  channelId String
  name      String
  startsAt  DateTime
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  stamps    Stamp[]
  rewards   Reward[]
  createdAt DateTime  @default(now())
}

model Stamp {
  id        String   @id @default(cuid())
  channelId String
  seasonId  String?
  title     String
  imageUrl  String
  kind      String   @default("daily")
  liveKey   String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  season  Season?       @relation(fields: [seasonId], references: [id])
  viewers ViewerStamp[]
}

model ViewerStamp {
  id        String   @id @default(cuid())
  channelId String
  viewerKey String
  stampId   String
  earnedAt  DateTime @default(now())

  stamp Stamp @relation(fields: [stampId], references: [id])

  @@unique([viewerKey, stampId])
}

model Reward {
  id             String   @id @default(cuid())
  channelId      String
  seasonId       String?
  title          String
  description    String
  requiredStamps Int
  createdAt      DateTime @default(now())

  season Season? @relation(fields: [seasonId], references: [id])
}
