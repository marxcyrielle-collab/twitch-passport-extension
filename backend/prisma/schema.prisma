generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Season {
  id        String   @id @default(cuid())
  channelId String
  name      String
  startsAt  DateTime
  endsAt    DateTime?
  isActive  Boolean  @default(true)
  stamps    Stamp[]
  rewards   Reward[]
  createdAt DateTime @default(now())
}

model Stamp {
  id        String   @id @default(cuid())
  channelId String
  seasonId  String?
  title     String
  imageUrl  String
  kind      String   @default("daily")
  liveKey   String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  season    Season? @relation(fields: [seasonId], references: [id])
  viewers   ViewerStamp[]
}

model ViewerStamp {
  id        String   @id @default(cuid())
  channelId String
  viewerKey String
  stampId   String
  earnedAt  DateTime @default(now())

  stamp     Stamp @relation(fields: [stampId], references: [id])

  @@unique([viewerKey, stampId])
}

model Reward {
  id             String   @id @default(cuid())
  channelId      String
  seasonId       String?
  title          String
  description    String
  requiredStamps Int
  createdAt      DateTime @default(now())

  season         Season? @relation(fields: [seasonId], references: [id])
}
model ChannelSettings {
  id            String   @id @default(cuid())
  channelId     String   @unique
  coverColor    String   @default("#4b145f")
  pageColor     String   @default("#f7e4b5")
  textColor     String   @default("#1b0b00")
  buttonColor   String   @default("#6b1b75")
  borderColor   String   @default("#a06a2c")
  activeStampId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}